# Copy this file's variable NAMES into Vercel's dashboard (Project Settings ->
# Environment Variables) with your REAL values. Never commit an actual .env
# file with real secrets to this folder - Vercel is where these live.

# Stripe dashboard -> Developers -> API keys (use your test keys until you're
# ready to charge real cards, then switch to live keys - same variable names).
STRIPE_SECRET_KEY=sk_test_...

# Stripe dashboard -> Developers -> Webhooks -> (your endpoint) -> Signing secret.
# You only get this after creating the webhook endpoint, which needs your
# Vercel URL first - see the README for the exact order of operations.
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase dashboard -> Project Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# The SERVICE ROLE key, not the anon key - this one is a real secret, never
# put it in js/supabase-config.js or anywhere else the browser can read it.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Your live site URL, no trailing slash - used to build Stripe's redirect URLs.
# Use your Vercel URL until your domain is pointed here, then switch to
# https://omriinvestments.com
SITE_URL=https://your-project.vercel.app
